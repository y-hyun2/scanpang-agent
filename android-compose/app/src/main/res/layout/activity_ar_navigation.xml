<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <io.github.sceneview.ar.ARSceneView
        android:id="@+id/sceneView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout
        android:id="@+id/uiContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- 상단 검색바 -->
        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:orientation="horizontal"
            android:padding="12dp">

            <EditText
                android:id="@+id/searchInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:background="@drawable/search_bg"
                android:hint="목적지 검색"
                android:paddingHorizontal="16dp"
                android:textSize="16sp" />

            <Button
                android:id="@+id/searchButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:backgroundTint="#6200EE"
                android:text="검색"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <!-- 상단 내비 카드 -->
        <LinearLayout
            android:id="@+id/navCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginTop="72dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/nav_card_bg"
            android:elevation="8dp"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/direction_icon_bg">

                    <ImageView
                        android:id="@+id/directionIcon"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_gravity="center"
                        android:src="@android:drawable/ic_menu_directions" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/navDistanceText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--m"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/navInstructionText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="경로 탐색 중..."
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- 텔레메트리 -->
        <TextView
            android:id="@+id/telemetryView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="start|top"
            android:layout_marginStart="16dp"
            android:layout_marginTop="300dp"
            android:background="#99000000"
            android:padding="8dp"
            android:textColor="#00FF00"
            android:textSize="12sp" />

        <!-- CompassView -->
        <com.hufs.arnavigation_com.CompassView
            android:id="@+id/compassView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="bottom"
            android:layout_marginBottom="220dp"
            android:visibility="gone" />

        <!-- 하단 미니맵 컨테이너 -->
        <FrameLayout
            android:id="@+id/miniMapContainer"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_gravity="bottom"
            android:visibility="gone">


            <fragment
                android:id="@+id/miniMap"
                android:name="com.google.android.gms.maps.SupportMapFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </FrameLayout>

    </FrameLayout>

</FrameLayout>